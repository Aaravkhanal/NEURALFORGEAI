# ============================================================
# NEURALFORGE — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the app to run.
# Variables marked [OPTIONAL] enhance functionality but are not mandatory.

# ============================================================
# LLM PROVIDERS — At least ONE is required
# ============================================================

# [REQUIRED — at least one] NVIDIA API Catalog key for Llama-3.1, Codestral, Nemotron
# Create at: https://build.nvidia.com/
NVIDIA_API_KEY=

# [OPTIONAL] OpenAI API key for GPT-4o, GPT-4, etc.
OPENAI_API_KEY=

# [OPTIONAL] Anthropic API key for Claude models
ANTHROPIC_API_KEY=

# [OPTIONAL] Groq API key for fast Llama/Mixtral inference (original ML.GUIDE provider)
GROQ_API_KEY=

# Default LLM provider: nvidia | openai | anthropic | groq
DEFAULT_LLM_PROVIDER=nvidia

# Default model name (provider-specific)
DEFAULT_MODEL_NAME=meta/llama-3.1-70b-instruct

# ============================================================
# SEARCH & RESEARCH TOOLS
# ============================================================

# [OPTIONAL] Tavily search API — recommended for web search tool
TAVILY_API_KEY=

# [OPTIONAL] Serper Google search API — alternative to Tavily
SERPER_API_KEY=

# [OPTIONAL] Jina AI Reader API — preserved from original ML.GUIDE
JINA_API_KEY=

# ============================================================
# OAUTH AUTHENTICATION
# ============================================================

# [REQUIRED for auth] Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [REQUIRED for auth] GitHub OAuth App credentials
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# SECURITY
# ============================================================

# [REQUIRED] Secret key for JWT token signing (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-256-bit-secret

# [REQUIRED] Secret key for NextAuth.js sessions (generate: openssl rand -hex 32)
NEXTAUTH_SECRET=change-me-to-another-random-secret

# [REQUIRED] Public URL of the frontend (used for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# DATABASE
# ============================================================

# [REQUIRED] Database connection URL
# Local dev (SQLite): sqlite+aiosqlite:///./neuralforge.db
# Production (PostgreSQL): postgresql+asyncpg://user:pass@host:5432/neuralforge
# Free PostgreSQL: https://neon.tech or https://supabase.com
DATABASE_URL=sqlite+aiosqlite:///./neuralforge.db

# ============================================================
# REDIS (Optional — app degrades gracefully without it)
# ============================================================

# [OPTIONAL] Redis URL for caching, rate limiting, and pub/sub
REDIS_URL=

# ============================================================
# FILE STORAGE
# ============================================================

# [OPTIONAL] Storage backend: local | gcs
STORAGE_BACKEND=local

# [OPTIONAL] Local upload directory
UPLOAD_DIR=./uploads

# [OPTIONAL] Google Cloud Storage bucket name
GCS_BUCKET_NAME=

# [OPTIONAL] Path to GCS service account JSON key
GCS_CREDENTIALS_JSON=

# ============================================================
# APPLICATION CONFIG
# ============================================================

# [REQUIRED] Backend API URL (for frontend to call)
BACKEND_URL=http://localhost:8000

# [REQUIRED] Frontend URL (for CORS and OAuth)
FRONTEND_URL=http://localhost:3000

# Environment: development | staging | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=50

# ============================================================
# OPTIONAL INTEGRATIONS
# ============================================================

# [OPTIONAL] OpenRouter API key — access to 100+ models via single key
OPENROUTER_API_KEY=

# [OPTIONAL] AWS credentials for S3 storage (alternative to GCS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ============================================================
# EXTERNAL DATASET APIs
# ============================================================
KAGGLE_API_TOKEN=
HF_TOKEN=
